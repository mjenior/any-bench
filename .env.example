# LLM Provider API Keys — copy to .env and fill in values
# Only the keys for providers you intend to use are required.

# Anthropic (default target model: anthropic/claude-opus-4.8)
ANTHROPIC_API_KEY=

# Google / Gemini (default judge model: gemini/gemini-3.5-flash)
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Cohere
COHERE_API_KEY=

# Mistral
MISTRAL_API_KEY=
